# Nestora Environment Configuration

# Database
DATABASE_URL="postgresql://nestora:nestora123@localhost:5432/nestora?schema=public"

# JWT
JWT_SECRET="nestora-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# NextAuth (Frontend)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="nestora-nextauth-secret-change-in-production"

# API URL
NEXT_PUBLIC_API_URL="http://localhost:4000"
API_URL="http://localhost:4000"

# Redis
REDIS_URL="redis://localhost:6379"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# MinIO / S3
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="nestora"
S3_SECRET_KEY="nestora12345"
S3_BUCKET="nestora"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# App
NODE_ENV="development"
PORT=4000
